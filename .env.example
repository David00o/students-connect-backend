# Application
APP_NAME=StudentsConnect
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/students_connect

# JWT
JWT_SECRET_KEY=change-this-jwt-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@studentsconnect.com
EMAIL_FROM_NAME=Students Connect

# OTP
OTP_EXPIRE_MINUTES=10

# Redis (for future use)
REDIS_URL=redis://redis:6379/0
